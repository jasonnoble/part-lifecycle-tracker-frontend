# Dev: relative path → calls go through the Vite proxy (Step 6).
# Prod (set in Cloudflare Pages, Step 7): the API origin, e.g. https://partledger.jasonnoble.dev
VITE_API_BASE_URL=/api

# Stytch public (publishable) token for the passwordless magic-link flow,
# e.g. public-token-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx. Find it in the
# Stytch dashboard → API Keys; also register <origin>/authenticate as a
# Redirect URL there. Safe to ship in the browser bundle. Leave unset to
# disable magic-link sign-in (the one-click demo logins work without it).
VITE_STYTCH_PUBLIC_TOKEN=
