# Dev: relative path → calls go through the Vite proxy (Step 6).
# Prod (set in Cloudflare Pages, Step 7): the API origin, e.g. https://partledger.jasonnoble.dev
VITE_API_BASE_URL=/api

# Stytch public (publishable) token for the passwordless magic-link flow.
# Find it in the Stytch dashboard → API Keys. Safe to ship in the browser
# bundle. If unset, magic-link sign-in is disabled but the one-click demo
# logins still work.
VITE_STYTCH_PUBLIC_TOKEN=public-token-test-00000000-0000-0000-0000-000000000000
